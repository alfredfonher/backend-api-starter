# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5050/backend_api_starter?schema=public
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5050/backend_api_starter_test?schema=public

# Authentication
JWT_SECRET=replace-with-at-least-32-characters
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=*

# Seed
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-in-local-env
